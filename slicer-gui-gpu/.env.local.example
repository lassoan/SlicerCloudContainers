# Example environment variables for docker-compose
# Copy this to .env and adjust values as needed

# 3D Slicer Configuration
SLICER_VERSION=5.10.0

# VNC Configuration
VNC_PASSWORD=mypass
VNC_GEOMETRY=1920x1080
VNC_DEPTH=24

# Display Configuration
DISPLAY_WIDTH=1920
DISPLAY_HEIGHT=1080

# Resource Limits
SHM_SIZE=4gb

# Container Names
CONTAINER_NAME=slicer-app-1

# Port Configuration
NOVNC_PORT=6080
VNC_PORT=5901

# GPU Configuration
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility,graphics

# Cloudflare Tunnel Configuration (Optional)
# To enable Cloudflare Tunnel, uncomment and fill in the following:
# 1. Get your tunnel token from Cloudflare dashboard
# 2. Set the tunnel name from your Cloudflare configuration
# 3. Set your domain (must be configured in Cloudflare DNS)

# CLOUDFLARE_TUNNEL_TOKEN=eyJh...QRt09
# CLOUDFLARE_TUNNEL_NAME=my-slicer-tunnel
# CLOUDFLARE_TUNNEL_DOMAIN=slicer.example.com
