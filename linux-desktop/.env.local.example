# Copy this file to .env.local and set values for your machine.
# This file is host-specific and should not be committed.

# Required for VNC and SSH access. Set to any non-empty value to enable, but a strong password is recommended if the container is exposed to untrusted networks.
VNC_PASSWORD=
SSH_PASSWORD=
# Cloudflare tunnel tokens for VNC and SSH access. Required for remote access via Cloudflare Tunnel. Generate these tokens in the Cloudflare dashboard and set them here to enable remote access.
CF_VNC_TUNNEL_TOKEN=
CF_SSH_TUNNEL_TOKEN=

# Persistent storage directory. Will contain subfolders: config (e.g., syncthing configuration data), workspace (folder synchronized by syncthing), and data (large file storage, not synchronized).
STORAGE_DIR=
